{
	"schemaVersion": 1,
	"id": "patchwork",
	"version": "${version}",
	"name": "Patchwork",
	"description": "Right-click or press R (configurable) to place a random placeable block from your hotbar or full inventory. Shift+Right Click to toggle between Hotbar and Inventory mode.",
	"authors": [
		"Cuebitt"
	],
	"contact": {
		"homepage": "https://github.com/cuebitt/trowel-key",
		"sources": "https://github.com/cuebitt/trowel-key"
	},
	"license": "MIT",
	"icon": "assets/patchwork/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"cuebitt.patchwork.client.PatchworkClient"
		],
		"modmenu": [
			"cuebitt.patchwork.client.ModMenuIntegration"
		]
	},
	"mixins": [
		"patchwork.client.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.17.2",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*"
	}
}